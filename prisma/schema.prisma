// OPERO — Prisma Schema
// Multi-tenant shared-schema architecture
// Organization = Tenant (Better Auth Organization plugin)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────
// BETTER AUTH CORE TABLES
// ─────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sessions    Session[]
  accounts    Account[]
  members     Member[]
  invitations Invitation[]
  inviteLinks TenantInviteLink[]

  // TenantRecord back-references (named relations)
  tasksCreated          Task[]          @relation("TaskCreatedBy")
  flowsCreated          Flow[]          @relation("FlowCreatedBy")
  campaignsCreated      Campaign[]      @relation("CampaignCreatedBy")
  contactsCreated       Contact[]       @relation("ContactCreatedBy")
  rolesCreated          Role[]          @relation("RoleCreatedBy")
  goalsCreated          Goal[]          @relation("GoalCreatedBy")
  salesCreated          Sale[]          @relation("SaleCreatedBy")
  invoicesCreated       Invoice[]       @relation("InvoiceCreatedBy")
  transactionsCreated   Transaction[]   @relation("TransactionCreatedBy")
  productsCreated       Product[]       @relation("ProductCreatedBy")
  assetsCreated         Asset[]         @relation("AssetCreatedBy")
  documentsCreated      Document[]      @relation("DocumentCreatedBy")
  foldersCreated        Folder[]        @relation("FolderCreatedBy")
  socialChannelsCreated SocialChannel[] @relation("SocialChannelCreatedBy")
  contentPostsCreated   ContentPost[]   @relation("ContentPostCreatedBy")
  chatChannelsCreated   ChatChannel[]   @relation("ChatChannelCreatedBy")
  chatMessagesCreated   ChatMessage[]   @relation("ChatMessageCreatedBy")
  chatReads             ChatRead[]
  tasksAssigned         Task[]          @relation("TaskAssignee")
  documentsUploaded     Document[]      @relation("DocumentUploadedBy")

  tasksUpdated          Task[]          @relation("TaskUpdatedBy")
  flowsUpdated          Flow[]          @relation("FlowUpdatedBy")
  campaignsUpdated      Campaign[]      @relation("CampaignUpdatedBy")
  contactsUpdated       Contact[]       @relation("ContactUpdatedBy")
  rolesUpdated          Role[]          @relation("RoleUpdatedBy")
  goalsUpdated          Goal[]          @relation("GoalUpdatedBy")
  salesUpdated          Sale[]          @relation("SaleUpdatedBy")
  invoicesUpdated       Invoice[]       @relation("InvoiceUpdatedBy")
  transactionsUpdated   Transaction[]   @relation("TransactionUpdatedBy")
  productsUpdated       Product[]       @relation("ProductUpdatedBy")
  assetsUpdated         Asset[]         @relation("AssetUpdatedBy")
  documentsUpdated      Document[]      @relation("DocumentUpdatedBy")
  foldersUpdated        Folder[]        @relation("FolderUpdatedBy")
  socialChannelsUpdated SocialChannel[] @relation("SocialChannelUpdatedBy")
  contentPostsUpdated   ContentPost[]   @relation("ContentPostUpdatedBy")
  chatChannelsUpdated   ChatChannel[]   @relation("ChatChannelUpdatedBy")
  chatMessagesUpdated   ChatMessage[]   @relation("ChatMessageUpdatedBy")

  // TenantActivity back-reference
  tenantActivities TenantActivity[]
  presenceRecords  UserPresence[]

  @@map("user")
}

model Session {
  id                   String   @id @default(cuid())
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  activeOrganizationId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ─────────────────────────────────────────────────────────
// BETTER AUTH ORGANIZATION PLUGIN TABLES (Tenant = Org)
// ─────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  metadata    String?  @db.Text
  status      String   @default("active") // "active" | "inactive"
  createdById String?
  createdAt   DateTime @default(now())

  // Relations
  members          Member[]
  invitations      Invitation[]
  inviteLinks      TenantInviteLink[]
  tasks            Task[]
  flows            Flow[]
  campaigns        Campaign[]
  contacts         Contact[]
  roles            Role[]
  goals            Goal[]
  sales            Sale[]
  invoices         Invoice[]
  transactions     Transaction[]
  products         Product[]
  assets           Asset[]
  documents        Document[]
  folders          Folder[]
  socialChannels   SocialChannel[]
  contentPosts     ContentPost[]
  chatChannels     ChatChannel[]
  chatMessages     ChatMessage[]
  chatReads        ChatRead[]
  tenantActivities TenantActivity[]
  userPresence     UserPresence[]

  // Custom OPERO extensions
  inviteCode     String?         @unique // Permanent join code (e.g., OP-XXXX-XXXX)
  tenantSettings TenantSettings?
  tenantPlan     TenantPlan?

  @@index([createdById])
  @@map("organization")
}

model Member {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  role           String // "owner" | "admin" | "member" (staff)
  department     String?
  position       String?
  status         String    @default("active") // "active" | "suspended"
  lastActive     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String? // role to assign on accept
  status         String   @default("pending") // "pending" | "accepted" | "rejected" | "cancelled"
  expiresAt      DateTime
  inviterId      String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model TenantInviteLink {
  id             String    @id @default(cuid())
  token          String    @unique
  organizationId String
  createdById    String
  expiresAt      DateTime?
  uses           Int       @default(0)
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("tenant_invite_link")
}

// ─────────────────────────────────────────────────────────
// OPERO CUSTOM TABLES (all scoped to tenant via organizationId)
// ─────────────────────────────────────────────────────────

/// Tenant-level configuration (1:1 with Organization)
model TenantSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  timezone       String   @default("UTC")
  locale         String   @default("en")
  brandColor     String?
  logoUrl        String?
  websiteUrl     String?
  industryType   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

/// Subscription plans catalog (shared, not tenant-scoped)
model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique // "free" | "pro" | "ultra"
  displayName String
  maxMembers  Int      @default(1)
  createdAt   DateTime @default(now())

  tenantPlans TenantPlan[]

  @@map("subscription_plan")
}

/// Active subscription for each tenant
model TenantPlan {
  id               String    @id @default(cuid())
  organizationId   String    @unique
  planId           String
  status           String    @default("active") // "active" | "cancelled" | "past_due"
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("tenant_plan")
}

/// Tenant activity log
model TenantActivity {
  id             String   @id @default(cuid())
  organizationId String
  module         String
  action         String
  entityId       String?
  entityType     String?
  entityName     String?
  description    String?
  userId         String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, module])
  @@map("tenant_activity")
}

// ─────────────────────────────────────────────────────────
// NEW FEATURE MODELS (TENANT AWARE)
// ─────────────────────────────────────────────────────────

/// Lightweight tenant-scoped online presence heartbeat
model UserPresence {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  lastSeenAt     DateTime @updatedAt
  isOnline       Boolean  @default(true)
  currentPage    String?
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([lastSeenAt])
  @@map("user_presence")
}

model Task {
  id             String    @id @default(cuid())
  organizationId String
  title          String?
  description    String?   @db.Text
  status         String?
  priority       String?
  dueDate        DateTime?
  startDate      DateTime?
  reminderDate   DateTime?
  estimatedHours Float?
  assigneeId     String?
  campaignId     String?
  labels         Json      @default("[]")
  assignees      Json      @default("[]")
  checklist      Json      @default("[]")
  subtasks       Json      @default("[]")
  relationships  Json      @default("[]")
  externalLinks  Json      @default("[]")
  comments       Json      @default("[]")
  reactions      Json?
  activity       Json      @default("[]")
  attachments    Json      @default("[]")
  watchers       Json      @default("[]")
  project        String?
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("TaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  assignee     User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, campaignId])
  @@index([assigneeId])
  @@map("task")
}

model Flow {
  id             String    @id @default(cuid())
  organizationId String
  title          String?
  name           String
  category       String    @default("Operations")
  description    String?
  status         String?
  progress       Int       @default(0)
  stages         Json      @default("[]")
  notes          Json      @default("[]")
  dueDate        DateTime?
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("FlowCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("FlowUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("flow")
}

model Campaign {
  id               String    @id @default(cuid())
  organizationId   String
  title            String?
  name             String?
  objective        String?   @db.Text
  description      String?   @db.Text
  status           String?
  priority         String?
  startDate        DateTime?
  endDate          DateTime?
  budget           Float?
  currency         String?
  tags             Json      @default("[]")
  assignedStaff    Json      @default("[]")
  campaignAccounts Json      @default("[]")
  goals            Json      @default("[]")
  activities       Json      @default("[]")
  attachments      Json      @default("[]")
  notes            String?   @db.Text
  payload          Json?
  createdById      String?
  updatedById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("CampaignUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  tasks Task[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, startDate])
  @@map("campaign")
}

model Contact {
  id               String   @id @default(cuid())
  organizationId   String
  title            String?
  name             String?
  relationshipType String?
  status           String?
  industry         String?
  description      String?  @db.Text
  persons          Json     @default("[]")
  tags             Json     @default("[]")
  assignedStaff    Json     @default("[]")
  notes            String?  @db.Text
  payload          Json?
  createdById      String?
  updatedById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("ContactUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, relationshipType])
  @@map("contact")
}

model Role {
  id             String   @id @default(cuid())
  organizationId String
  title          String?
  name           String?
  description    String?  @db.Text
  status         String?
  permissions    Json     @default("[]")
  color          String?
  sortOrder      Int      @default(0)
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("RoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("RoleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("role")
}

model Goal {
  id             String    @id @default(cuid())
  organizationId String
  title          String?
  targetOutcome  String?   @db.Text
  description    String?   @db.Text
  status         String?
  priority       String?
  metric         String?
  targetValue    Float?
  currentValue   Float?
  progress       Int       @default(0)
  startDate      DateTime?
  dueDate        DateTime?
  ownerId        String?
  tags           Json      @default("[]")
  activities     Json      @default("[]")
  notes          String?   @db.Text
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("GoalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("GoalUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([ownerId])
  @@map("goal")
}

model Sale {
  id                 String   @id @default(cuid())
  organizationId     String
  saleNumber         String?
  title              String?
  status             String?
  saleType           String?
  paymentStatus      String?
  customerName       String?
  recipientName      String?
  contactName        String?
  contactId          String?
  items              Json     @default("[]")
  subtotal           Float    @default(0)
  discountAmount     Float    @default(0)
  taxAmount          Float    @default(0)
  grandTotal         Float    @default(0)
  currency           String   @default("USD")
  orderDiscountValue Float?
  orderDiscountType  String?
  discountTotal      Float    @default(0)
  taxPercentage      Float?
  notes              String?  @db.Text
  assignedStaff      Json     @default("[]")
  activities         Json     @default("[]")
  attachments        Json     @default("[]")
  shippingAddress    String?
  trackingNumber     String?
  payload            Json?
  createdById        String?
  updatedById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("SaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("SaleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  invoices     Invoice[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, saleNumber])
  @@map("sale")
}

model Invoice {
  id               String    @id @default(cuid())
  organizationId   String
  invoiceNumber    String?
  title            String?
  status           String?
  recipientName    String?
  recipientEmail   String?
  contactName      String?
  contactId        String?
  issueDate        DateTime?
  dueDate          DateTime?
  items            Json      @default("[]")
  subtotal         Float     @default(0)
  discountAmount   Float     @default(0)
  discountRate     Float?
  discountTotal    Float     @default(0)
  taxRate          Float?
  taxAmount        Float     @default(0)
  taxTotal         Float     @default(0)
  totalAmount      Float     @default(0)
  currency         String    @default("USD")
  paymentStatus    String?
  paymentMethod    String?
  paidAt           DateTime?
  paymentReference String?
  saleId           String?
  saleOrderNumber  String?
  notes            String?   @db.Text
  activities       Json      @default("[]")
  attachments      Json      @default("[]")
  payload          Json?
  createdById      String?
  updatedById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sale         Sale?        @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, invoiceNumber])
  @@index([organizationId, dueDate])
  @@index([saleId])
  @@map("invoice")
}

model Transaction {
  id              String    @id @default(cuid())
  organizationId  String
  type            String?
  title           String?
  amount          Float     @default(0)
  currency        String    @default("USD")
  category        String?
  transactionDate DateTime?
  paymentMethod   String?
  reference       String?
  sourceType      String?
  sourceId        String?
  status          String?
  contactName     String?
  contactId       String?
  notes           String?   @db.Text
  activities      Json      @default("[]")
  attachments     Json      @default("[]")
  payload         Json?
  createdById     String?
  updatedById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("TransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("TransactionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([organizationId, transactionDate])
  @@index([organizationId, sourceType, sourceId])
  @@map("transaction")
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  title          String?
  name           String?
  sku            String?
  category       String?
  type           String   @default("Physical")
  price          Float    @default(0)
  currency       String   @default("USD")
  stock          Int      @default(0)
  totalQuantity  Int      @default(0)
  minThreshold   Int      @default(10)
  status         String?
  description    String?  @db.Text
  imageUrl       String?
  variants       Json     @default("[]")
  activities     Json     @default("[]")
  notes          String?  @db.Text
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, sku])
  @@index([organizationId, category])
  @@map("product")
}

model Asset {
  id             String    @id @default(cuid())
  organizationId String
  title          String?
  name           String?
  category       String?
  assetCode      String?
  quantity       Int       @default(1)
  status         String?
  assignedTo     Json      @default("[]")
  assignedToId   String?
  location       String?
  purchaseDate   DateTime?
  purchaseValue  Float?
  currency       String?
  warrantyExpiry DateTime?
  supplierName   String?
  imageUrl       String?
  activities     Json      @default("[]")
  comments       Json      @default("[]")
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("AssetUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, assetCode])
  @@index([organizationId, category])
  @@map("asset")
}

model Document {
  id             String   @id @default(cuid())
  organizationId String
  title          String?
  description    String?  @db.Text
  status         String?
  fileName       String?
  fileType       String?
  fileSize       Int?
  storagePath    String?
  fileUrl        String?
  downloadUrl    String?
  folderId       String?
  tags           Json     @default("[]")
  uploadedById   String?
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("DocumentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("DocumentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  folder       Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy   User?        @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, folderId])
  @@index([uploadedById])
  @@map("document")
}

model Folder {
  id             String   @id @default(cuid())
  organizationId String
  title          String?
  name           String?
  description    String?  @db.Text
  status         String?
  parentId       String?
  color          String?
  sortOrder      Int      @default(0)
  tags           Json     @default("[]")
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("FolderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("FolderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  parent       Folder?      @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Folder[]     @relation("FolderHierarchy")
  documents    Document[]

  @@index([organizationId])
  @@index([organizationId, parentId])
  @@map("folder")
}

model SocialChannel {
  id             String    @id @default(cuid())
  organizationId String
  title          String?
  platform       String?
  accountName    String?
  handle         String?
  profileUrl     String?
  status         String?
  followers      Int       @default(0)
  postsThisMonth Int       @default(0)
  interactions   Int       @default(0)
  monthlyReach   Int?
  averageViews   Int?
  lastActiveDate DateTime?
  notes          String?   @db.Text
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("SocialChannelCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?         @relation("SocialChannelUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  contentPosts ContentPost[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, platform])
  @@map("social_channel")
}

model ContentPost {
  id              String    @id @default(cuid())
  organizationId  String
  title           String?
  status          String?
  plannedDate     DateTime?
  plannedTime     String?
  contentType     String?
  targetAccountId String?
  tags            Json      @default("[]")
  payload         Json?
  createdById     String?
  updatedById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("ContentPostCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?          @relation("ContentPostUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  targetAccount SocialChannel? @relation(fields: [targetAccountId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, plannedDate])
  @@index([targetAccountId])
  @@map("content_post")
}

model ChatChannel {
  id             String   @id @default(cuid())
  organizationId String
  name           String?
  description    String?
  type           String   @default("public")
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ChatChannelCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("ChatChannelUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  reads        ChatRead[]

  @@index([organizationId])
  @@map("chat_channel")
}

model ChatMessage {
  id             String   @id @default(cuid())
  organizationId String
  channelId      String?
  senderId       String?
  content        String?
  type           String   @default("text")
  status         String?
  payload        Json?
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ChatMessageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("ChatMessageUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  readMarkers  ChatRead[]

  @@index([organizationId])
  @@index([organizationId, channelId])
  @@index([channelId, createdAt])
  @@map("chat_message")
}

model ChatRead {
  id                String   @id @default(cuid())
  organizationId    String
  userId            String
  channelId         String
  lastReadMessageId String?
  lastReadAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel         ChatChannel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  lastReadMessage ChatMessage? @relation(fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId, channelId])
  @@index([organizationId, userId])
  @@index([channelId])
  @@map("chat_reads")
}
