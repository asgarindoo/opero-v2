// OPERO — Prisma Schema
// Multi-tenant shared-schema architecture
// Organization = Tenant (Better Auth Organization plugin)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────
// BETTER AUTH CORE TABLES
// ─────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  sessions    Session[]
  accounts    Account[]
  members     Member[]
  invitations Invitation[]
  inviteLinks TenantInviteLink[]

  // TenantRecord back-references (named relations)
  tasksCreated            Task[]           @relation("TaskCreatedBy")
  flowsCreated            Flow[]           @relation("FlowCreatedBy")
  campaignsCreated        Campaign[]       @relation("CampaignCreatedBy")
  contactsCreated         Contact[]        @relation("ContactCreatedBy")
  rolesCreated            Role[]           @relation("RoleCreatedBy")
  goalsCreated            Goal[]           @relation("GoalCreatedBy")
  salesCreated            Sale[]           @relation("SaleCreatedBy")
  invoicesCreated         Invoice[]        @relation("InvoiceCreatedBy")
  transactionsCreated     Transaction[]    @relation("TransactionCreatedBy")
  productsCreated         Product[]        @relation("ProductCreatedBy")
  assetsCreated           Asset[]          @relation("AssetCreatedBy")
  documentsCreated        Document[]       @relation("DocumentCreatedBy")
  foldersCreated          Folder[]         @relation("FolderCreatedBy")
  botsCreated             Bot[]            @relation("BotCreatedBy")
  reportsCreated          Report[]         @relation("ReportCreatedBy")
  socialChannelsCreated   SocialChannel[]  @relation("SocialChannelCreatedBy")
  socialSchedulesCreated  SocialSchedule[] @relation("SocialScheduleCreatedBy")
  socialActivitiesCreated SocialActivity[] @relation("SocialActivityCreatedBy")
  contentPostsCreated     ContentPost[]    @relation("ContentPostCreatedBy")
  contentAssetsCreated    ContentAsset[]   @relation("ContentAssetCreatedBy")
  chatChannelsCreated     ChatChannel[]    @relation("ChatChannelCreatedBy")
  chatMessagesCreated     ChatMessage[]    @relation("ChatMessageCreatedBy")

  tasksUpdated            Task[]           @relation("TaskUpdatedBy")
  flowsUpdated            Flow[]           @relation("FlowUpdatedBy")
  campaignsUpdated        Campaign[]       @relation("CampaignUpdatedBy")
  contactsUpdated         Contact[]        @relation("ContactUpdatedBy")
  rolesUpdated            Role[]           @relation("RoleUpdatedBy")
  goalsUpdated            Goal[]           @relation("GoalUpdatedBy")
  salesUpdated            Sale[]           @relation("SaleUpdatedBy")
  invoicesUpdated         Invoice[]        @relation("InvoiceUpdatedBy")
  transactionsUpdated     Transaction[]    @relation("TransactionUpdatedBy")
  productsUpdated         Product[]        @relation("ProductUpdatedBy")
  assetsUpdated           Asset[]          @relation("AssetUpdatedBy")
  documentsUpdated        Document[]       @relation("DocumentUpdatedBy")
  foldersUpdated          Folder[]         @relation("FolderUpdatedBy")
  botsUpdated             Bot[]            @relation("BotUpdatedBy")
  reportsUpdated          Report[]         @relation("ReportUpdatedBy")
  socialChannelsUpdated   SocialChannel[]  @relation("SocialChannelUpdatedBy")
  socialSchedulesUpdated  SocialSchedule[] @relation("SocialScheduleUpdatedBy")
  socialActivitiesUpdated SocialActivity[] @relation("SocialActivityUpdatedBy")
  contentPostsUpdated     ContentPost[]    @relation("ContentPostUpdatedBy")
  contentAssetsUpdated    ContentAsset[]   @relation("ContentAssetUpdatedBy")
  chatChannelsUpdated     ChatChannel[]    @relation("ChatChannelUpdatedBy")
  chatMessagesUpdated     ChatMessage[]    @relation("ChatMessageUpdatedBy")

  // TenantActivity back-reference
  tenantActivities TenantActivity[]
  presenceRecords  UserPresence[]

  @@map("user")
}

model Session {
  id                   String   @id @default(cuid())
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  activeOrganizationId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ─────────────────────────────────────────────────────────
// BETTER AUTH ORGANIZATION PLUGIN TABLES (Tenant = Org)
// ─────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  metadata    String?  @db.Text
  status      String   @default("active") // "active" | "inactive"
  createdById String?
  createdAt   DateTime @default(now())

  // Relations
  members          Member[]
  invitations      Invitation[]
  inviteLinks      TenantInviteLink[]
  tasks            Task[]
  flows            Flow[]
  campaigns        Campaign[]
  contacts         Contact[]
  roles            Role[]
  goals            Goal[]
  sales            Sale[]
  invoices         Invoice[]
  transactions     Transaction[]
  products         Product[]
  assets           Asset[]
  documents        Document[]
  folders          Folder[]
  bots             Bot[]
  reports          Report[]
  socialChannels   SocialChannel[]
  socialSchedules  SocialSchedule[]
  socialActivities SocialActivity[]
  contentPosts     ContentPost[]
  contentAssets    ContentAsset[]
  chatChannels     ChatChannel[]
  chatMessages     ChatMessage[]
  tenantActivities TenantActivity[]
  userPresence     UserPresence[]

  // Custom OPERO extensions
  inviteCode     String?         @unique // Permanent join code (e.g., OP-XXXX-XXXX)
  tenantSettings TenantSettings?
  tenantPlan     TenantPlan?

  @@index([createdById])
  @@map("organization")
}

model Member {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  role           String // "owner" | "admin" | "member" (staff)
  department     String?
  position       String?
  status         String    @default("active") // "active" | "suspended"
  lastActive     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String? // role to assign on accept
  status         String   @default("pending") // "pending" | "accepted" | "rejected" | "cancelled"
  expiresAt      DateTime
  inviterId      String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model TenantInviteLink {
  id             String    @id @default(cuid())
  token          String    @unique
  organizationId String
  createdById    String
  expiresAt      DateTime?
  uses           Int       @default(0)
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("tenant_invite_link")
}

// ─────────────────────────────────────────────────────────
// OPERO CUSTOM TABLES (all scoped to tenant via organizationId)
// ─────────────────────────────────────────────────────────

/// Tenant-level configuration (1:1 with Organization)
model TenantSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  timezone       String   @default("UTC")
  locale         String   @default("en")
  brandColor     String?
  logoUrl        String?
  websiteUrl     String?
  industryType   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

/// Subscription plans catalog (shared, not tenant-scoped)
model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique // "free" | "pro" | "ultra"
  displayName String
  maxMembers  Int      @default(1)
  maxBots     Int      @default(1)
  features    Json     @default("{}")
  createdAt   DateTime @default(now())

  tenantPlans TenantPlan[]

  @@map("subscription_plan")
}

/// Active subscription for each tenant
model TenantPlan {
  id               String    @id @default(cuid())
  organizationId   String    @unique
  planId           String
  status           String    @default("active") // "active" | "cancelled" | "past_due"
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("tenant_plan")
}

/// Tenant activity log
model TenantActivity {
  id             String   @id @default(cuid())
  organizationId String
  module         String
  action         String
  entityId       String?
  entityType     String?
  entityName     String?
  description    String?
  userId         String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, module])
  @@map("tenant_activity")
}

// ─────────────────────────────────────────────────────────
// NEW FEATURE MODELS (TENANT AWARE)
// ─────────────────────────────────────────────────────────

/// Lightweight tenant-scoped online presence heartbeat
model UserPresence {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  lastSeenAt     DateTime @updatedAt
  currentPage    String?
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([lastSeenAt])
  @@map("user_presence")
}

